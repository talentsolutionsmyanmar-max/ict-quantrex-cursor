# Copy to .env and adjust (optional for backtests — Binance public klines need no key).
#   cp .env.example .env

# App (default 5050 avoids macOS AirPlay on 5000)
PORT=5050
FLASK_SECRET_KEY=change-me-in-production

# Paper / live only (leave empty for backtest-only)
BINANCE_API_KEY=
BINANCE_SECRET=

# Optional integrations
UNUSUAL_WHALES_API_KEY=
UW_CLIENT_API_ID=100001
OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-4o-mini

# Kill-zone background evolution (off unless set)
KZ_AUTO_RESEARCH=0
KZ_POLL_INTERVAL_SEC=60
KZ_RESEARCH_LOOKBACK_DAYS=120
KZ_RESEARCH_POPULATION=6
KZ_RESEARCH_GENERATIONS=1
KZ_RESEARCH_VERIFY_TOP=1
KZ_RESEARCH_MIN_GAP_SEC=2700

# Set to 1 to force live klines fetch every time (slower)
DISABLE_KLINES_CACHE=0
