# Copy to .env and adjust (optional for backtests — Binance public klines need no key).
#   cp .env.example .env

# App (default 5050 avoids macOS AirPlay on 5000)
PORT=5050
FLASK_SECRET_KEY=change-me-in-production

# Paper / live only (leave empty for backtest-only)
BINANCE_API_KEY=
BINANCE_SECRET=
# Optional: USDT-M futures REST root (premiumIndex / funding); public, no key
BINANCE_FUTURES_API=https://fapi.binance.com/fapi/v1

# Optional integrations
UNUSUAL_WHALES_API_KEY=
UW_CLIENT_API_ID=100001
OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-4o-mini

# VPS 24/7: start paper loop when Gunicorn loads (optional; needs Binance + risk OK)
PAPER_TRADING_AUTOSTART=0

# Kill-zone background evolution (off unless set). Under Gunicorn, requires import via wsgi (enabled by default).
KZ_AUTO_RESEARCH=0
KZ_POLL_INTERVAL_SEC=60
KZ_RESEARCH_LOOKBACK_DAYS=120
KZ_RESEARCH_POPULATION=6
KZ_RESEARCH_GENERATIONS=1
KZ_RESEARCH_VERIFY_TOP=1
KZ_RESEARCH_MIN_GAP_SEC=2700

# Set to 1 to force live klines fetch every time (slower)
DISABLE_KLINES_CACHE=0

# Paper trade alerts — free Telegram Bot API (https://api.telegram.org — no OpenRouter)
# 1) @BotFather → /newbot → token → put here. 2) Message your bot (/start). 3) Run:
#    python3 scripts/telegram_discover_chat.py
#    (paste TELEGRAM_CHAT_ID it prints; skip browser getUpdates — often errors with tokens)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: random string so only you can POST /api/alerts/test-telegram
TELEGRAM_TEST_SECRET=
ALERT_WEBHOOK_URL=
# Set to 1 to also notify on TP / SL / exits (can be chatty)
ALERT_ON_PAPER_EXIT=0
