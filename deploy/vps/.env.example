# =============================================================================
# Copy this file to: /home/trader/ict-backend/.env
# Never commit real secrets. chmod 600 .env on the server.
# =============================================================================

# --- Flask / Gunicorn ---
PORT=5050
FLASK_DEBUG=0
# Long random string (e.g. openssl rand -hex 32)
FLASK_SECRET_KEY=replace-with-long-random-string

# Behind Caddy/nginx — correct https + Socket.IO URLs
TRUST_PROXY=1

# Gunicorn uses eventlet via systemd; optional override (threading for dev only)
# SOCKETIO_ASYNC_MODE=eventlet

# --- Binance (optional but recommended for paper / rate limits) ---
BINANCE_API_KEY=
BINANCE_SECRET=

# --- Unusual Whales (optional; US flow features) ---
# UNUSUAL_WHALES_API_KEY=
# UW_CLIENT_API_ID=100001

# --- Kill-zone auto-research (optional; CPU-heavy on small droplets) ---
KZ_AUTO_RESEARCH=0
KZ_POLL_INTERVAL_SEC=60

# --- Chief QE: scripts/chief_qe_sweep.py + weekly timer ---
# Full 8-coin basket (overrides run-weekly-qe.sh default of SOL,ETH,BTC)
SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT

# Optional date window for sweeps (defaults come from config/spec if unset)
# START_DATE=2024-01-01
# END_DATE=2024-12-31
# TIMEFRAME=1h
# N_WINDOWS=3
# FRICTION_MULT=1.5

# Optional: lock sweeps to promoted genes (JSON object, one line)
# GENES_JSON={"ATR_MULTIPLIER":1.8,"FVG_THRESHOLD":0.001,"ICT_RANGE_HOURS":5,"LIQUIDITY_BUFFER":0.006,"MIN_CONFLUENCE":2,"MIN_SIGNAL_STRENGTH":68,"TRAIL_ATR_MULTIPLIER":1}
